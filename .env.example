# Frontend public variables. These are bundled into the Vue app.
VITE_STATIC_DATA_PATH=/data/app-data.json
VITE_PDF_BRIEF_ENDPOINT=/briefs/client.pdf
VITE_SITE_ORIGIN=https://your-production-origin.example
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0

# Build-time local table output.
BE_SURE_ANCE_DATA_DIR=src/be-sure-ance-app/public/data

# Netlify scheduled refresh. Store the real URL as a GitHub Actions secret.
NETLIFY_BUILD_HOOK_URL=

# Private Telegram bot token from BotFather. Never expose this in frontend env.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional Sentry-compatible backend/scraper error reporting.
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
