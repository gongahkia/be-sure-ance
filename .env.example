# Frontend public variables. These are bundled into the Vue app.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-sb-publishable-key
VITE_PDF_BRIEF_ENDPOINT=/briefs/client.pdf
VITE_SHARE_ENDPOINT=/shares
VITE_SITE_ORIGIN=https://your-production-origin.example
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0

# Backend/scraper private variables. Never expose these in frontend env.
SUPABASE_URL=https://your-project-ref.supabase.co

# Preferred current Supabase server key for scrapers/GitHub Actions.
SUPABASE_SECRET_KEY=your-sb-secret-key

# Private Supabase Storage bucket for raw brochure PDFs.
BROCHURE_STORAGE_BUCKET=plan-brochures

# Private Telegram bot token from BotFather. Never expose this in frontend env.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional Sentry-compatible backend/scraper error reporting.
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# Legacy fallback if the project still uses JWT service_role keys.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# Local Docker demo note:
# docker compose up --build injects fake local values for the demo API.
# Do not replace those compose values with production secrets.
