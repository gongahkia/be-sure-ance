# Frontend public variables. These are bundled into the Vue app.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-sb-publishable-key
VITE_PDF_BRIEF_ENDPOINT=/briefs/client.pdf
VITE_SITE_ORIGIN=https://your-production-origin.example

# Backend/scraper private variables. Never expose these in frontend env.
SUPABASE_URL=https://your-project-ref.supabase.co

# Preferred current Supabase server key for scrapers/GitHub Actions.
SUPABASE_SECRET_KEY=your-sb-secret-key

# Private Supabase Storage bucket for raw brochure PDFs.
BROCHURE_STORAGE_BUCKET=plan-brochures

# Legacy fallback if the project still uses JWT service_role keys.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt
